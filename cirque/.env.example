# Copy to .env.local and fill in. Never commit .env.local.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Anthropic (client-side fallback when edge parsing is off)
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# Set to true to call Supabase Edge Function `parse-food` (set ANTHROPIC_API_KEY secret on the project).
EXPO_PUBLIC_USE_FOOD_PARSE_EDGE=

# Edge Functions `parse-food` and `refuel` need ANTHROPIC_API_KEY in Supabase project secrets. Deploy: supabase functions deploy refuel

# Strava API application (https://www.strava.com/settings/api). Redirect / Authorization Callback Domain must include your app redirect (e.g. cirque://strava via Expo).
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Nutritionix (https://developer.nutritionix.com/)
EXPO_PUBLIC_NUTRITIONIX_APP_ID=
EXPO_PUBLIC_NUTRITIONIX_API_KEY=
