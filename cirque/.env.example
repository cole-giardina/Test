# Copy to .env.local and fill in. Never commit .env.local.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Dev only: direct Claude calls from the app when EXPO_PUBLIC_USE_FOOD_PARSE_EDGE is not true.
# Release / production JS bundles always use the `parse-food` Edge Function — do not ship a client key to the App Store.
EXPO_PUBLIC_ANTHROPIC_API_KEY=

# In __DEV__, set true to use Edge Function `parse-food` (matches production). Requires ANTHROPIC_API_KEY in Supabase secrets.
EXPO_PUBLIC_USE_FOOD_PARSE_EDGE=

# Edge Functions `parse-food` and `refuel` need ANTHROPIC_API_KEY in Supabase project secrets.

# EAS: `eas build` sets EAS_BUILD_PROFILE. For `production` and `preview`, the app config strips
# EXPO_PUBLIC_ANTHROPIC_API_KEY from the bundle extra (use Edge-only parsing in release).
# Verify Supabase secrets before shipping: `supabase secrets list` (ANTHROPIC_API_KEY for functions).

# Strava API application (https://www.strava.com/settings/api). Redirect / Authorization Callback Domain must include your app redirect (e.g. cirque://strava via Expo).
EXPO_PUBLIC_STRAVA_CLIENT_ID=

# Nutritionix (https://developer.nutritionix.com/)
EXPO_PUBLIC_NUTRITIONIX_APP_ID=
EXPO_PUBLIC_NUTRITIONIX_API_KEY=
